<%- include('./partials/head.ejs') %>
<link rel="stylesheet" href="/css/index.css">
<%- include('./partials/header.ejs') %>

<main>
    <% Pets.forEach(pet=>{%>
      <section id="pet-info">
      <h1><%=pet.name  %></h1>
      <h2>Owner: <%= pet.owner %></h2>
        <h3>Vet:<%= pet.vet %></h3>
        <p>Species: <%= pet.species %></p>
        <section id="buttons">
          <a href="/update/<%= pet._id %>">Update</a>
        <form action="/delete/<%= pet._id  %>" method="POST">
          <button type="submit">Delete</button>
        </form>
        </section>
        </section>
  <%  }) %>
</main>

</body>
</html>